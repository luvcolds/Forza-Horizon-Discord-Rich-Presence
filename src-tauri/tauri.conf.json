{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forza Rich Presence",
  "version": "0.1.0",
  "identifier": "com.forzarp.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Forza Horizon RPC Settings",
        "width": 360,
        "height": 530,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}